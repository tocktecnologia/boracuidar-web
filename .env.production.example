# Frontend production environment
#
# Configure this to enable the server-side booking flow.
# When omitted, the frontend falls back to the legacy client-side booking flow.

VITE_BOOKING_API_URL=https://boracuidar-booking-api-xxxxxx-uc.a.run.app

# PostHog product analytics + session replay
# Leave VITE_PUBLIC_POSTHOG_KEY empty to disable PostHog.
VITE_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
